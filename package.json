{
  "name": "stellar-game-studio",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "setup": "bun run scripts/setup.ts",
    "build": "bun run scripts/build.ts",
    "deploy": "bun run scripts/deploy.ts",
    "bindings": "bun run scripts/bindings.ts",
    "create": "bun run scripts/create.ts",
    "publish": "bun run scripts/publish.ts",
    "dev": "bun --cwd=sgs_frontend run dev",
    "dev:game": "bun run scripts/dev-game.ts",
    "dev:backend": "bun --cwd=backend run dev",
    "start:backend": "bun --cwd=backend run start",
    "build:circuits": "./scripts/build-badge-circuit.sh",
    "build:circuits:prove": "./scripts/build-badge-circuit.sh --prove"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^14.5.0"
  }
}
